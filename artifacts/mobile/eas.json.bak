{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "production": {
      "workflow": "managed",
      "ios": {
        "buildType": "archive"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development": {
      "workflow": "managed",
      "distribution": "internal",
      "ios": {
        "buildType": "simulator"
      }
    }
  }
}
